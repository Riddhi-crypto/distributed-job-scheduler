# ─────────────────────────────────────────────────────────────────────────────
# AEGIS environment. Copy to .env for manual (non-Docker) runs:
#     cp .env.example .env
# Docker Compose sets these itself, so you don't need a .env when using Compose.
# ─────────────────────────────────────────────────────────────────────────────

# --- shared: database connection (used by backend, worker, and DB tests) ------
DATABASE_URL=postgres://aegis:aegis@localhost:5432/aegis

# --- API server (backend/) ----------------------------------------------------
PORT=4000
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Reliability tuning (seconds)
LEASE_SECONDS=30           # how long a worker's claim on a job is valid
HEARTBEAT_TIMEOUT=45       # a worker is considered dead after this without a beat
DISPATCHER_LEASE=15        # dispatcher leader-election lease length

# --- Worker (worker/) ---------------------------------------------------------
WORKER_CONCURRENCY=4       # parallel jobs per worker process
WORKER_POLL_MS=750         # how often the worker polls for claimable jobs
WORKER_HEARTBEAT_MS=5000   # heartbeat + lease-renewal interval
# WORKER_NAME=worker-1     # optional friendly name (defaults to host-pid)

# --- Frontend (frontend/) -----------------------------------------------------
# Where the Vite dev server proxies /api. Localhost for manual runs; the Compose
# file overrides this to http://api:4000 inside the Docker network.
VITE_API_TARGET=http://localhost:4000
